<?xml version="1.0" encoding="UTF-8" ?>
<component type="desktop-application">
  <id>dev.mohfy.quizbite</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Quizbite</name>
  <summary>Create and play quizzes</summary>
  <description>
    <p
        >Create quizzes with multiple choice questions. Add an optional image per question. Export quizzes to PDF.</p>
    <p>Import and export quiz files. Keep a local quiz library.</p>
  </description>

  <developer id="dev.mohfy">
    <name>mohfy</name>
  </developer>

  <url type="homepage">https://github.com/mohfy/quizbite</url>
  <url type="vcs-browser">https://github.com/mohfy/quizbite</url>
  <url type="bugtracker">https://github.com/mohfy/quizbite/issues</url>

  <translation type="gettext">quizbite</translation>
  <launchable type="desktop-id">dev.mohfy.quizbite.desktop</launchable>
  <content_rating type="oars-1.1" />

  <screenshots>
    <screenshot type="default">
      <caption
                xml:lang="en"
            >Browse and manage quizzes in your local library</caption>
      <image
                type="source"
            >https://raw.githubusercontent.com/mohfy/quizbite/18a37004b3234cc7c78a0852416fccd19791ef39/data/screenshots/Quiz%20Library.png</image>
    </screenshot>
    <screenshot>
      <caption
                xml:lang="en"
            >Create multiple choice quizzes with optional images</caption>
      <image
                type="source"
            >https://raw.githubusercontent.com/mohfy/quizbite/18a37004b3234cc7c78a0852416fccd19791ef39/data/screenshots/Quiz%20Editor.png</image>
    </screenshot>
    <screenshot>
      <caption xml:lang="en">Play quizzes and review your score</caption>
      <image
                type="source"
            >https://raw.githubusercontent.com/mohfy/quizbite/18a37004b3234cc7c78a0852416fccd19791ef39/data/screenshots/Quiz%20Player.png</image>
    </screenshot>
    <screenshot>
      <caption xml:lang="en">Add images to quiz questions when needed</caption>
      <image
                type="source"
            >https://raw.githubusercontent.com/mohfy/quizbite/18a37004b3234cc7c78a0852416fccd19791ef39/data/screenshots/Image%20Support.png</image>
    </screenshot>
  </screenshots>

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1a5fb4</color>
  </branding>

  <releases>
  <release version="1.5.1" date="2026-04-20">
    <description>
      <p>Added Italian Translation (@albanobattistella)</p>
    </description>
  </release>
  <release version="1.5.0" date="2026-04-14">
    <description>
      <p>Flashcards update!</p>
    </description>
  </release>
    <release version="1.0.0" date="2026-04-10">
      <description>
        <p>First release.</p>
      </description>
    </release>
  </releases>

</component>
