import os
import sys
import signal
import locale
import gettext

VERSION = '@VERSION@'
pkgdatadir = '@pkgdatadir@'
localedir = '@localedir@'

sys.path.insert(1, pkgdatadir)
signal.signal(signal.SIGINT, signal.SIG_DFL)
try:
    locale.setlocale(locale.LC_ALL, "")
except locale.Error:
    pass
locale.bindtextdomain('quizbite', localedir)
locale.textdomain('quizbite')
gettext.bindtextdomain('quizbite', localedir)
gettext.textdomain('quizbite')

if __name__ == '__main__':
    import gi

    from gi.repository import Gio
    resource = Gio.Resource.load(os.path.join(pkgdatadir, 'quizbite.gresource'))
    resource._register()

    from quizbite import main
    sys.exit(main.main(VERSION))
