using Gtk 4.0;
using Adw 1;

Adw.ShortcutsDialog shortcuts_dialog {
  Adw.ShortcutsSection {
    title: _("Shortcuts");

    Adw.ShortcutsItem {
      title: C_("shortcut window", "Create Quiz");
      action-name: "app.create";
    }

    Adw.ShortcutsItem {
      title: C_("shortcut window", "Import Study Set");
      action-name: "app.import";
    }

    Adw.ShortcutsItem {
      title: C_("shortcut window", "Quit");
      action-name: "app.quit";
    }
  }
}
