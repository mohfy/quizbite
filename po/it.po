msgid "Create and play quizzes"
msgstr "Crea e gioca ai quiz"

#: data/dev.mohfy.quizbite.metainfo.xml.in:11
msgid ""
"Create quizzes with multiple choice questions. Add an optional image per "
"question. Export quizzes to PDF."
msgstr ""
"Crea quiz con domande a scelta multipla. Aggiungi un'immagine opzionale per "
"ogni domanda. Esporta i quiz in PDF."

#: data/dev.mohfy.quizbite.metainfo.xml.in:12
msgid "Import and export quiz files. Keep a local quiz library."
msgstr "Importa ed esporta file di quiz. Mantieni una libreria di quiz locale."

#: data/dev.mohfy.quizbite.metainfo.xml.in:16
msgid "mohfy"
msgstr "mohfy"

#: data/dev.mohfy.quizbite.metainfo.xml.in:35
msgid "First release."
msgstr "Prima versione."

#: src/data/quiz_file.py:45
msgid "Question image must be a JSON object."
msgstr "L'immagine della domanda deve essere un oggetto JSON."

#: src/data/quiz_file.py:52
msgid "Question image filename is required."
msgstr "Il nome file dell'immagine della domanda è obbligatorio."

#: src/data/quiz_file.py:55
msgid "Question image media_type is required."
msgstr "Il media_type dell'immagine della domanda è obbligatorio."

#: src/data/quiz_file.py:58
msgid "Question image media_type must be an image MIME type."
msgstr "Il media_type dell'immagine della domanda deve essere un tipo MIME immagine."

#: src/data/quiz_file.py:61
msgid "Question image data is required."
msgstr "I dati dell'immagine della domanda sono obbligatori."

#: src/data/quiz_file.py:66
msgid "Question image data must be valid base64."
msgstr "I dati dell'immagine della domanda devono essere base64 validi."

#: src/data/quiz_file.py:78
msgid "Quiz file must contain a JSON object."
msgstr "Il file del quiz deve contenere un oggetto JSON."

#: src/data/quiz_file.py:82
msgid "Quiz title is required."
msgstr "Il titolo del quiz è obbligatorio."

#: src/data/quiz_file.py:86
msgid "Quiz must include at least one question."
msgstr "Il quiz deve includere almeno una domanda."

#: src/data/quiz_file.py:91
msgid "Each question must be a JSON object."
msgstr "Ogni domanda deve essere un oggetto JSON."

#: src/data/quiz_file.py:99
msgid "Each question needs text."
msgstr "Ogni domanda richiede un testo."

#: src/data/quiz_file.py:102
msgid "Each question must have at least two options."
msgstr "Ogni domanda deve avere almeno due opzioni."

#: src/data/quiz_file.py:107
msgid "Options must be non-empty strings."
msgstr "Le opzioni devono essere stringhe non vuote."

#: src/data/quiz_file.py:113
msgid "Each question must have a valid correct_index."
msgstr "Ogni domanda deve avere un correct_index valido."

